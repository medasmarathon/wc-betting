rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function activeUser() {
      return signedIn() && userDoc().data.isActive == true;
    }

    function adminUser() {
      return activeUser() && userDoc().data.role == "ADMIN";
    }

    match /users/{userId} {
      allow read: if activeUser() && (request.auth.uid == userId || adminUser());
      allow write: if false;
    }

    match /invites/{emailKey} {
      allow read: if adminUser();
      allow write: if false;
    }

    match /matches/{matchId} {
      allow read: if activeUser();
      allow write: if false;
    }

    match /bets/{betId} {
      allow read: if activeUser() && (resource.data.userId == request.auth.uid || adminUser());
      allow write: if false;
    }

    match /walletTransactions/{transactionId} {
      allow read: if activeUser() && (resource.data.userId == request.auth.uid || adminUser());
      allow write: if false;
    }

    match /leaderboard/{userId} {
      allow read: if activeUser();
      allow write: if false;
    }

    match /auditLogs/{logId} {
      allow read: if adminUser();
      allow write: if false;
    }
  }
}
